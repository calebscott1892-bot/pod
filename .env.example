# Spare Space — copy to .env.local and fill in.

# Resend — powers the Rentals enquiry form (enquiries deliver to sparespacerentals@gmail.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=caleb@c4studios.com.au

# Stripe — powers Studios checkout (keys from Paul's Stripe account)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Base URL for Stripe success/cancel redirects (set per deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000
